    "adaptability_explanation" : {
      "comment" : "Explanation text in the \"Adaptability\" section of the settings sheet.",
      "extractionState" : "extracted_with_value",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einige Sprachen benötigen mehr Platz. SwiftUI verwendet die ViewThatFits-Komponente, um das Layout vertikal umzubrechen, falls der Satz nicht auf den Bildschirm passt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some languages require more space. SwiftUI uses the ViewThatFits component to stack the layout vertically if the sentence doesn't fit on the screen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Alguns idiomas exigem mais espaço. O SwiftUI utiliza o componente ViewThatFits para quebrar o layout verticalmente caso a frase não caiba na tela."
          }
        }
      }
    },
